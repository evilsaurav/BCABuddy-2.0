# BCABuddy Azure Production Environment Template
# Copy these keys into Azure App Service -> Configuration -> Application settings

SECRET_KEY=replace-with-long-random-secret
GROQ_API_KEY=replace-with-groq-key
BACKEND_CORS_ORIGINS=["https://your-frontend-domain.com","https://www.your-frontend-domain.com"]

# Optional
WEBSITES_PORT=8000
BCABUDDY_CHAT_MODEL=llama-3.3-70b-versatile
PASSWORD_RESET_FRONTEND_BASE_URL=https://your-frontend-domain.com

# Azure Communication Services Email (for forgot-password emails)
AZURE_EMAIL_CONNECTION_STRING=
AZURE_EMAIL_SENDER=DoNotReply@your-domain.azurecomm.net

# Optional Supabase avatar storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AVATAR_BUCKET=avatars
